# Chat backend — choose one:
# Local Gemini CLI server (recommended for development):
VITE_CHAT_URL=http://localhost:5002/chat

# Supabase Edge Function (for cloud deployment):
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
# VITE_SUPABASE_PROJECT_ID=your-project-id

# Persistence mode: "local" uses localStorage, "supabase" uses Supabase
# VITE_USE_LOCAL_PERSISTENCE=true

# ── Server Configuration ──
# EFL_PORT=5002
# EFL_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Model Selection (override per-phase) ──
# EFL_PLAN_MODEL=gemini-2.5-flash
# EFL_EXEC_MODEL=gemini-2.5-flash
# EFL_VERIFY_MODEL=gemini-2.5-flash
# EFL_AUDIT_MODEL=gemini-2.5-flash
# EFL_SYNTH_MODEL=gemini-2.5-flash
# EFL_REFLECT_MODEL=gemini-2.5-flash

# ── Pipeline Tuning ──
# EFL_MAX_RETRIES=1
# EFL_MAX_AUDIT_LOOPS=2

# ── Provider Selection ──
# EFL_PROVIDER=auto      # "auto" (CLI→API fallback), "cli" (Gemini CLI only), "api" (REST API only)
# EFL_API_PROVIDER=gemini # "openai", "gemini", "anthropic", "deepseek"
# EFL_API_MODEL=          # Override API model (e.g., "gpt-4o", "claude-sonnet-4-20250514")
